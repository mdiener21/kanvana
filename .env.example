# .env.example — copy to .env and fill in values
# .env is gitignored; .env.example is committed.

# Frontend service port on the host side.
# Local Docker dev defaults to 8080.
# Set this to 80 in production if you want the container on the standard HTTP port.
NGINX_PORT=80

# PocketBase image version tag.
PB_VERSION=0.38.1

POCKETBASE_WORKDIR=/opt/pb
POCKETBASE_DATA_DIR=/opt/pb/data_dir
POCKETBASE_MIGRATION_DIR=/opt/pb/migrations
POCKETBASE_PUBLIC_DIR=/opt/pb/public
POCKETBASE_HOOK_DIR=/opt/pb/

POCKETBASE_HOME=/opt/pocketbase

POCKETBASE_ADMIN_EMAIL=admin@yourdomain.com
POCKETBASE_ADMIN_PASSWORD=strongpassword

# deploy env vars
APP_DIR="/my/app/dir"
SERVICE_NAME="kanvana_pb"
COMPOSE_FILE="docker-compose.yml"
HEALTH_URL="https://example.com/health"

